class Solution {
public:
int maxChunksToSorted(vector<int>& v) 
    {
        vector<int> v1=v;
		
        sort(v1.begin(),v1.end());
		
        int n=v.size(),i,j,ans=0;
        long long sum1=0,sum2=0;
        for(i=0;i<n;i++)
        {
            sum1+=v[i];
            sum2+=v1[i];
            if(sum1==sum2)
                ans++;
        }
        return ans;
    }
};
