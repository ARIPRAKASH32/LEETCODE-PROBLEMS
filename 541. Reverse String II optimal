class Solution {
public:
    string reverseStr(string s, int k) {
        int n = s.size();
        int i = 0, j = i+(k-1);
        while(i < n){
            int end = min(j+1, n);
            reverse(s.begin() + i, s.begin() + end);
            i += 2*k;
            j = i+(k-1);
        }
        return s;
    }
};
