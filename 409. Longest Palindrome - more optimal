class Solution {
public:
    int longestPalindrome(string s) {
        vector<size_t> hist(52, 0);

        for (size_t i = 0; i < s.size(); ++i) {
            size_t idx =
                s[i] >= 'a' && s[i] <= 'z' ? (s[i] - 'a') : (s[i] - 'A' + 26);

            ++hist[idx];
        }

        int res = 0;

        bool odd_found = false;

        for (size_t i = 0; i < hist.size(); ++i)
        {
            if ((hist[i] & 1) == 1)
            {
                if (!odd_found)
                {
                    odd_found = true;
                    ++res;
                }
                res += hist[i] - (hist[i] & 1); 
            }
            else if ((hist[i] & 1) == 0)
            {
                res += hist[i];
            }
        }

        return res - (odd_found ? !(res & 1) : 0);
    }
};
