#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int n, m;
    vector<int> nums1, nums2;
    vector<vector<int>> dp;

    int solve(int i, int j) {
        if (i >= n || j >= m)
            return -1000000000;

        if (dp[i][j] != INT_MIN)
            return dp[i][j];

        int ans = -1000000000;

        ans = max(ans, nums1[i] * nums2[j] + max(0, solve(i + 1, j + 1)));
        ans = max(ans, solve(i + 1, j));
        ans = max(ans, solve(i, j + 1));

        return dp[i][j] = ans;
    }

    int maxDotProduct(vector<int>& a, vector<int>& b) {
        nums1 = a;
        nums2 = b;
        n = nums1.size();
        m = nums2.size();

        dp.assign(n, vector<int>(m, INT_MIN));
        return solve(0, 0);
    }
};

int main() {
    int n, m;
    cin >> n;
    vector<int> nums1(n);
    for (int i = 0; i < n; i++)
        cin >> nums1[i];

    cin >> m;
    vector<int> nums2(m);
    for (int i = 0; i < m; i++)
        cin >> nums2[i];

    Solution sol;
    cout << sol.maxDotProduct(nums1, nums2);

    return 0;
}
