n = int(input())

for i in range(1, n + 1):
    print(" " * (n - i), end="")
    for a in range(1, i + 1):
        print(a, end="")
    for a in range(i - 1, 0, -1):
        print(a, end="")
    print()

for i in range(n - 1, 0, -1):
    print(" " * (n - i), end="")
    for a in range(1, i + 1):
        print(a, end="")
    for a in range(i - 1, 0, -1):
        print(a, end="")
    print()

