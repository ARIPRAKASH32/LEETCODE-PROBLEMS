class Solution {
public:
    bool judgeCircle(string moves) {
        pair<int,int> x = {0,0};

        for(int i = 0 ; i < moves.length(); i++){
            if(moves[i] == 'U'){
                x.first++;
            }
            else if(moves[i] == 'D'){
                x.first--;
            }
            else if(moves[i] == 'R'){
                x.second++;
            }
            else if(moves[i] == 'L'){
                x.second--;
            }
        }

        if(x.first == 0 && x.second == 0){
            return true;
        }

        return false;
    }
};
