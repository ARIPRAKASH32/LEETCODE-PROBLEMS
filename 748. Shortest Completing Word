class Solution {
public:
    string shortestCompletingWord(string licensePlate, vector<string>& words) {
        int a[26] = {0};
        for(char d: licensePlate){
            if((d>='a' and d<='z')){
                a[d-'a']++;
            }
            if(d >= 'A' and d<='Z'){
                a[d-'A']++;
            }
        }

        // for(int i = 0;i<26;i++) cout<<a[i]<<" "; cout<<"\n";


        int min = 1001;
        string res = "";

        for(int i = 0;i<words.size();i++){
            if(min <= words[i].size()) continue;

            int temp[26];
            for(int j = 0;j<26;j++) temp[j] = a[j];

            for(char d: words[i]){
            if((d>='a' and d<='z')){
                temp[d-'a']--;
            }
            if(d >= 'A' and d<='Z'){
                temp[d-'A']--;
            }}

            int j = 0;
            for(j = 0;j<26;j++) {
                if(temp[j] > 0){
                    break;
                }
            }

            if(j == 26) {
                res = words[i];
                min = res.length();
            }
        }
        
        return res;
    }
};
