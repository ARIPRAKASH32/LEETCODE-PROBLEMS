class Solution {
public:
    int maxProduct(vector<string>& words) {
        vector<int> v(words.size(),0);
        for(int i=0;i<words.size();i++)
        {
            int num=0;
            for(int j=0;j<words[i].size();j++)
            {
                num|=1<<(words[i][j]-'a');
            }
            v[i]=num;
        }
        int res=0;
        for(int i=0;i<words.size();i++)
        {
            for(int j=i+1;j<words.size();j++)
            {
                if((v[i]&v[j]) == 0)
                {
                    res=max(res,(int)words[i].size()*(int)words[j].size());
                }
            }
        }
        return res;
    }
};
